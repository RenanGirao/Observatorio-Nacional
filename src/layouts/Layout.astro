---
import '../styles/dsgov.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Observatório da Participação Digital",
  description = "Dados, indicadores e evidências sobre processos de participação digital em um ambiente aberto, organizado e transparente.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <!-- Tipografia padrão gov.br: Rawline (fallback Raleway) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rawline:wght@300;400;500;600;700&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Iconografia padrão gov.br: Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha512-Avb2QiuDEEvB4bZJYdft2mNjVShBftLdPG8FJ0V7irTLQ8Uo0qcPxh4Plq7G5tGm0rU+1SPhVotteLpBERwTkw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-to-content" href="#conteudo-principal">Pular para o conteúdo</a>
    <slot />
  </body>
</html>

<style is:global>
  /* ===== DESIGN TOKENS — Padrão mínimo gov.br (Blue Warm) ===== */
  :root {
    /* Blue Warm — paleta oficial DSGOV */
    --dsgov-blue-10:  #DBE8FB;
    --dsgov-blue-20:  #ADCDFF;
    --dsgov-blue-40:  #5992ED;
    --dsgov-blue-60:  #2670E8;  /* vivid-50 */
    --dsgov-blue-70:  #1351B4;  /* vivid-70 — primary */
    --dsgov-blue-80:  #0C326F;
    --dsgov-blue-90:  #071D41;  /* dark — header/footer bg */

    /* Aliases para compatibilidade com componentes existentes */
    --color-primary-95: #DBE8FB;
    --color-primary-80: #5992ED;
    --color-primary-60: #2670E8;
    --color-primary:    #1351B4;
    --color-primary-40: #0C326F;
    --color-primary-20: #071D41;
    --color-primary-10: #03112A;

    /* Complementary (terracotta) */
    --color-comp-95: #f2d6a9;
    --color-comp-80: #e5b15b;
    --color-comp-60: #cc8e28;
    --color-comp: #b27c23;
    --color-comp-40: #7f5613;
    --color-comp-20: #4c3207;

    /* Analogous */
    --color-ana-left-80: #2fadbf;
    --color-ana-left-60: #19727f;
    --color-ana-left-40: #09393f;
    --color-ana-right-80: #4939bf;
    --color-ana-right-60: #2b1f7f;
    --color-ana-right-40: #1a124f;

    /* Split Complementary */
    --color-split-left-80: #d84a36;
    --color-split-left-60: #992d1e;
    --color-split-left-40: #4c130b;
    --color-split-right-80: #bacc3d;
    --color-split-right-60: #737f1f;
    --color-split-right-40: #3a4010;

    /* Triadic */
    --color-tri-left-80: #d83673;
    --color-tri-left-60: #991e4c;
    --color-tri-left-40: #4c0b23;
    --color-tri-right-80: #72cc3d;
    --color-tri-right-60: #437f1f;
    --color-tri-right-40: #224010;

    /* Neutrals */
    --color-background: #f7f8fa;
    --color-surface: #ffffff;
    --color-foreground: #111827;
    --color-muted: #6b7280;
    --color-border: #e5e7eb;
    --color-on-primary: #ffffff;
    --color-on-comp: #ffffff;

    /* Semantic */
    --color-success: #17a34a;
    --color-warning: #eab308;
    --color-danger: #dc2626;
    --color-info: #18499b;

    /* Typography — padrão gov.br (Rawline → Raleway → system) */
    --font-sans: "Rawline", "Raleway", -apple-system, system-ui, sans-serif;
    --font-mono: ui-monospace, "JetBrains Mono", monospace;

    --text-display-size: 48px;
    --text-display-weight: 600;
    --text-display-leading: 1.1;
    --text-display-spacing: -0.02em;

    --text-h1-size: 32px;
    --text-h1-weight: 600;
    --text-h1-leading: 1.2;
    --text-h1-spacing: -0.01em;

    --text-h2-size: 24px;
    --text-h2-weight: 600;
    --text-h2-leading: 1.3;
    --text-h2-spacing: -0.01em;

    --text-h3-size: 20px;
    --text-h3-weight: 600;
    --text-h3-leading: 1.3;

    --text-body-lg-size: 18px;
    --text-body-lg-weight: 400;
    --text-body-lg-leading: 1.6;

    --text-body-md-size: 16px;
    --text-body-md-weight: 400;
    --text-body-md-leading: 1.6;

    --text-body-sm-size: 14px;
    --text-body-sm-weight: 400;
    --text-body-sm-leading: 1.5;

    --text-label-md-size: 14px;
    --text-label-md-weight: 500;
    --text-label-md-leading: 1.4;
    --text-label-md-spacing: 0.01em;

    --text-label-sm-size: 12px;
    --text-label-sm-weight: 500;
    --text-label-sm-leading: 1.4;
    --text-label-sm-spacing: 0.02em;

    --text-mono-md-size: 14px;
    --text-mono-sm-size: 12px;

    /* Spacing */
    --space-xs: 4px;
    --space-sm: 8px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 32px;
    --space-2xl: 48px;
    --space-3xl: 64px;
    --space-4xl: 80px;
    --gutter: 24px;
    --margin: 32px;

    /* Border Radius */
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --radius-full: 9999px;

    /* Layout */
    --max-width: 1200px;
    --header-height: 64px;
    --header-height-mobile: 56px;
  }

  /* ===== RESET & BASE ===== */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    font-size: var(--text-body-md-size);
    font-weight: var(--text-body-md-weight);
    line-height: var(--text-body-md-leading);
    color: var(--color-foreground);
    background-color: var(--color-background);
    scroll-behavior: smooth;
    scroll-padding-top: var(--header-height);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  @media (max-width: 640px) {
    html {
      scroll-padding-top: var(--header-height-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      transition-duration: 0ms !important;
      animation-duration: 0.01ms !important;
    }
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* ===== SKIP TO CONTENT ===== */
  .skip-to-content {
    position: absolute;
    top: -100%;
    left: var(--space-md);
    z-index: 1000;
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-sans);
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .skip-to-content:focus {
    top: var(--space-sm);
  }

  /* ===== UTILITY CLASSES ===== */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ===== TYPOGRAPHY ===== */
  h1 {
    font-size: var(--text-h1-size);
    font-weight: var(--text-h1-weight);
    line-height: var(--text-h1-leading);
    letter-spacing: var(--text-h1-spacing);
    margin: 0 0 var(--space-md);
  }

  h2 {
    font-size: var(--text-h2-size);
    font-weight: var(--text-h2-weight);
    line-height: var(--text-h2-leading);
    letter-spacing: var(--text-h2-spacing);
    margin: 0 0 var(--space-md);
  }

  h3 {
    font-size: var(--text-h3-size);
    font-weight: var(--text-h3-weight);
    line-height: var(--text-h3-leading);
    margin: 0 0 var(--space-sm);
  }

  p {
    margin: 0 0 var(--space-md);
  }

  .text-body-lg {
    font-size: var(--text-body-lg-size);
    font-weight: var(--text-body-lg-weight);
    line-height: var(--text-body-lg-leading);
  }

  .text-body-sm {
    font-size: var(--text-body-sm-size);
    font-weight: var(--text-body-sm-weight);
    line-height: var(--text-body-sm-leading);
  }

  .text-muted {
    color: var(--color-muted);
  }
</style>
