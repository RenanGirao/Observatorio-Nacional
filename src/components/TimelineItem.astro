---
export interface Props {
  year: string;
  title: string;
  description: string;
  position: "left" | "right";
}

const { year, title, description, position } = Astro.props;
---

<li class:list={["timeline-item", `timeline-item-${position}`]}>
  <article class="timeline-card">
    <span class="timeline-year">{year}</span>
    <h3 class="timeline-title">{title}</h3>
    <p class="timeline-desc">{description}</p>
  </article>
</li>

<style>
  .timeline-item {
    position: relative;
    width: 50%;
    padding: 0 var(--space-xl) var(--space-2xl) 0;
    list-style: none;
  }

  .timeline-item-right {
    margin-left: 50%;
    padding: 0 0 var(--space-2xl) var(--space-xl);
  }

  /* Dot */
  .timeline-item::before {
    content: "";
    position: absolute;
    top: 8px;
    width: 16px;
    height: 16px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    z-index: 1;
  }

  .timeline-item-left::before {
    right: -8px;
  }

  .timeline-item-right::before {
    left: -8px;
  }

  .timeline-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    max-width: 480px;
  }

  .timeline-item-left .timeline-card {
    margin-left: auto;
  }

  .timeline-item-right .timeline-card {
    margin-right: auto;
  }

  .timeline-year {
    display: inline-block;
    font-size: var(--text-label-sm-size);
    font-weight: var(--text-label-sm-weight);
    letter-spacing: var(--text-label-sm-spacing);
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .timeline-title {
    font-size: var(--text-h3-size);
    font-weight: var(--text-h3-weight);
    line-height: var(--text-h3-leading);
    color: var(--color-foreground);
    margin: 0 0 var(--space-sm);
  }

  .timeline-desc {
    font-size: var(--text-body-md-size);
    line-height: var(--text-body-md-leading);
    color: var(--color-muted);
    margin: 0;
  }

  @media (max-width: 900px) {
    .timeline-item,
    .timeline-item-right {
      width: 100%;
      margin-left: 0;
      padding: 0 0 var(--space-lg) var(--space-2xl);
    }

    .timeline-item::before {
      left: 9px;
    }

    .timeline-card {
      max-width: 100%;
    }

    .timeline-item-left .timeline-card,
    .timeline-item-right .timeline-card {
      margin: 0;
    }
  }
</style>
