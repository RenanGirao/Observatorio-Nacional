<footer class="footer">
  <div class="footer-main">
    <!-- Logo -->
    <div class="footer-logo-area">
      <a href="#topo" class="footer-logo" aria-label="Observatório da Participação Digital — Ir para o topo">
        <svg width="48" height="48" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="var(--color-primary-60)"/>
          <circle cx="12" cy="14" r="5" stroke="white" stroke-width="2" fill="none"/>
          <circle cx="12" cy="14" r="2" fill="white"/>
          <path d="M12 19v5M7 22l5-3M17 22l-5-3" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="22" cy="10" r="3" stroke="white" stroke-width="1.5" fill="none"/>
          <circle cx="22" cy="10" r="1" fill="white"/>
          <circle cx="20" cy="20" r="3" stroke="white" stroke-width="1.5" fill="none"/>
          <circle cx="20" cy="20" r="1" fill="white"/>
