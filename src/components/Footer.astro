          <circle cx="26" cy="15" r="0.8" fill="white"/>
        </svg>
        <span class="footer-logo-text">Observatório da<br/>Participação Digital</span>
      </a>
    </div>

    <!-- Link columns -->
    <div class="footer-columns">
      {navColumns.map(col => (
        <div class="footer-column">
          <h3 class="footer-heading">{col.heading}</h3>
          <ul class="footer-nav-list">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

