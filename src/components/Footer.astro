<style>
  .footer {
    background: var(--color-primary-10);
    color: var(--color-primary-95);
  }

  /* ===== Main section ===== */
  .footer-main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--gutter) var(--space-xl);
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--space-2xl);
  }

  .footer-logo-area {
    display: flex;
    align-items: flex-start;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .footer-logo-text {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-on-primary);
  }

  /* Columns */
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .footer-heading {
    font-size: var(--text-label-sm-size);
    font-weight: var(--text-label-sm-weight);
    letter-spacing: var(--text-label-sm-spacing);
    color: var(--color-primary-80);
    margin: 0 0 var(--space-md);
    text-transform: uppercase;
  }

  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-size: var(--text-body-md-size);
    color: var(--color-primary-95);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .footer-link:hover {
    color: var(--color-primary-80);
    text-decoration: underline;
  }

  /* ===== Bottom section ===== */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-lg) var(--gutter);
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md) var(--space-xl);
  }

  .footer-credit-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-md) var(--space-lg);
  }

  /* Logos row */
  .footer-logos {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .footer-logos a {
    display: flex;
    align-items: center;
    opacity: 0.85;
    transition: opacity 200ms ease;
  }

  .footer-logos a:hover {
    opacity: 1;
  }

  .cc-badge {
    display: flex;
    align-items: center;
    gap: 3px;
    opacity: 0.55;
    transition: opacity 200ms ease;
  }

  .cc-badge:hover {
    opacity: 0.8;
  }

  .cc-icon {
    flex-shrink: 0;
  }

  /* Credit text */
  .footer-site-credit {
    font-size: 12px;
    color: var(--color-primary-80);
    opacity: 0.6;
    margin: 0;
  }

  .footer-site-credit a {
    color: var(--color-primary-80);
    text-decoration: none;
  }

  .footer-site-credit a:hover {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .footer-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .footer-main {
      padding: var(--space-xl) var(--space-md);
    }

    .footer-bottom-inner {
      padding: var(--space-md);
    }

    .footer-columns {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .footer-logos {
      justify-content: center;
    }

    .footer-logo {
      margin-bottom: var(--space-lg);
    }
  }
</style>
