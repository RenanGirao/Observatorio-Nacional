---
const navColumns = [
  {
    heading: "Explorar",
    links: [
      { label: "Mapa interativo", href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/explorar-dados` },
      { label: "Linha do Tempo", href: "/#linha-do-tempo" },
      { label: "Plataformas", href: "/#plataformas" },
      { label: "Pesquisas", href: "/#pesquisas" },
    ],
  },
  {
    heading: "Dados",
    links: [
      { label: "Dados abertos", href: "/#dados-abertos" },
      { label: "Parceiros", href: "/#parceiros" },
    ],
  },
  {
    heading: "Institucional",
    links: [
      { label: "Sobre o OPD", href: "/#sobre" },
      { label: "Equipe Técnica", href: "#" },
      { label: "Acessibilidade", href: "#" },
    ],
  },
  {
    heading: "Contribuir",
    links: [
      { label: "Parceiros", href: "/#parceiros" },
      { label: "Código-fonte", href: "#" },
    ],
  },
];
