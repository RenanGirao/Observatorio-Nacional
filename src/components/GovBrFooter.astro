---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<footer class="br-footer" role="contentinfo">

  <!-- Bloco de logos -->
  <div class="br-footer-logos">
    <div class="br-container-lg">
      <div class="logos-inner">
        <a href="https://www.gov.br/pt-br" target="_blank" rel="noopener" aria-label="Portal Gov.br">
          <svg width="72" height="14" viewBox="0 0 72 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <text x="0" y="13" font-family="Rawline, Raleway, sans-serif" font-size="13" font-weight="700" fill="rgba(255,255,255,0.75)">gov.br</text>
          </svg>
        </a>
        <span class="br-divider-v" aria-hidden="true"></span>
        <a href={`${base}/`} class="footer-system-name" aria-label="Observatório Nacional da Participação Digital">
          Observatório Nacional da Participação Digital
        </a>
      </div>
    </div>
  </div>

  <!-- Navegação do rodapé -->
  <div class="br-footer-nav">
    <div class="br-container-lg">
      <nav aria-label="Links do rodapé">
        <ul class="footer-nav-list">
          <li>
            <span class="footer-nav-heading">Explorar</span>
            <ul>
              <li><a href={`${base}/explorar-dados`}>Mapa interativo</a></li>
              <li><a href={`${base}/#linha-do-tempo`}>Linha do Tempo</a></li>
              <li><a href={`${base}/#plataformas`}>Plataformas</a></li>
              <li><a href={`${base}/#pesquisas`}>Pesquisas</a></li>
            </ul>
          </li>
          <li>
            <span class="footer-nav-heading">Dados</span>
            <ul>
              <li><a href={`${base}/#dados-abertos`}>Dados abertos</a></li>
              <li><a href="https://dados.gov.br" target="_blank" rel="noopener">Portal de dados</a></li>
              <li><a href={`${base}/#parceiros`}>Parceiros</a></li>
            </ul>
          </li>
          <li>
            <span class="footer-nav-heading">Institucional</span>
            <ul>
              <li><a href={`${base}/#sobre`}>Sobre o OPD</a></li>
              <li><a href={`${base}/#submeter-pesquisa`}>Submeter pesquisa</a></li>
              <li><a href={`${base}/#parceiros`}>Contribuir</a></li>
            </ul>
          </li>
          <li>
            <span class="footer-nav-heading">Links úteis</span>
            <ul>
              <li><a href="https://brasilparticipativo.presidencia.gov.br" target="_blank" rel="noopener">Brasil Participativo</a></li>
              <li><a href="https://www.gov.br/pt-br" target="_blank" rel="noopener">Gov.br</a></li>
              <li><a href="https://github.com/RenanGirao/Observatorio-Nacional" target="_blank" rel="noopener">
                <i class="fab fa-github" aria-hidden="true"></i> Código-fonte
              </a></li>
            </ul>
          </li>
        </ul>
      </nav>
    </div>
  </div>

  <!-- Barra inferior (mini-footer) -->
  <div class="br-footer-bottom">
    <div class="br-container-lg">
      <div class="bottom-inner">
        <p class="footer-license">
          <i class="fas fa-lock-open" aria-hidden="true"></i>
          Conteúdo sob
          <a href="https://creativecommons.org/licenses/by-sa/4.0/deed.pt" target="_blank" rel="noopener license">
            Licença Creative Commons BY-SA 4.0
          </a>
        </p>
        <p class="footer-credit">
          Desenvolvido com dados abertos do
          <a href="https://brasilparticipativo.presidencia.gov.br" target="_blank" rel="noopener">Brasil Participativo</a>
        </p>
      </div>
    </div>
  </div>

</footer>

<style>
  /* =============================================
     DSGOV — Rodapé (padrão mínimo gov.br)
     ============================================= */

  .br-footer {
    font-family: var(--font-sans);
  }

  .br-container-lg {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Bloco de logos */
  .br-footer-logos {
    background: #071D41;
    border-top: 4px solid #1351B4;
    padding: 1rem 0;
  }

  .logos-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .br-divider-v {
    display: inline-block;
    width: 1px;
    height: 20px;
    background: rgba(255,255,255,0.3);
    flex-shrink: 0;
  }

  .footer-system-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
  }

  .footer-system-name:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Navegação */
  .br-footer-nav {
    background: #0C326F;
    padding: 2.5rem 0;
  }

  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .footer-nav-list > li {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-nav-heading {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    display: block;
    margin-bottom: 0.25rem;
  }

  .footer-nav-list > li > ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav-list a {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    transition: color 150ms;
  }

  .footer-nav-list a:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-nav-list a i {
    font-size: 0.875rem;
    opacity: 0.7;
  }

  /* Barra inferior */
  .br-footer-bottom {
    background: #071D41;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 0.875rem 0;
  }

  .bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-license,
  .footer-credit {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.45);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .footer-license a,
  .footer-credit a {
    color: rgba(255,255,255,0.6);
    text-underline-offset: 2px;
  }

  .footer-license a:hover,
  .footer-credit a:hover {
    color: rgba(255,255,255,0.85);
  }

  /* Responsivo */
  @media (max-width: 900px) {
    .footer-nav-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .footer-nav-list {
      grid-template-columns: 1fr;
    }
    .bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
