---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="br-header" id="br-header">
  <div class="br-header-top">
    <div class="br-header-logo">
      <a href="https://www.gov.br/pt-br" target="_blank" rel="noopener" aria-label="Portal Gov.br">
        <svg width="120" height="24" viewBox="0 0 120 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <text x="0" y="18" font-family="sans-serif" font-size="18" font-weight="700" fill="#1351b4">gov</text>
          <text x="42" y="18" font-family="sans-serif" font-size="18" fill="#1351b4">.br</text>
        </svg>
      </a>
      <span class="br-header-divider" aria-hidden="true"></span>
      <a href={`${base}/`} class="br-header-title" aria-label="Observatório Nacional da Participação Digital — página inicial">
        Observatório Nacional da Participação Digital
      </a>
    </div>

    <nav class="br-header-nav" aria-label="Navegação principal">
      <ul class="br-header-nav-list">
        <li><a href={`${base}/#sobre`}>Sobre</a></li>
        <li><a href={`${base}/#mapa`}>Mapa</a></li>
        <li><a href={`${base}/#linha-do-tempo`}>Linha do tempo</a></li>
        <li><a href={`${base}/#dados-abertos`}>Dados abertos</a></li>
        <li><a href={`${base}/#pesquisas`}>Pesquisas</a></li>
        <li><a href={`${base}/#parceiros`}>Parceiros</a></li>
        <li>
          <a href={`${base}/explorar-dados`} class="br-header-nav-cta">
            Explorar dados
          </a>
        </li>
      </ul>

      <button class="br-header-menu-btn" id="br-menu-btn" type="button" aria-label="Abrir menu" aria-expanded="false" aria-controls="br-mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>

  <!-- Menu mobile -->
  <div class="br-mobile-menu" id="br-mobile-menu" hidden>
    <ul>
      <li><a href={`${base}/#sobre`}>Sobre</a></li>
      <li><a href={`${base}/#mapa`}>Mapa</a></li>
      <li><a href={`${base}/#linha-do-tempo`}>Linha do tempo</a></li>
      <li><a href={`${base}/#dados-abertos`}>Dados abertos</a></li>
      <li><a href={`${base}/#pesquisas`}>Pesquisas</a></li>
      <li><a href={`${base}/#parceiros`}>Parceiros</a></li>
      <li><a href={`${base}/explorar-dados`}>Explorar dados</a></li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("br-menu-btn");
  const menu = document.getElementById("br-mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.hidden === false;
    if (menu) menu.hidden = open;
    btn.setAttribute("aria-expanded", String(!open));
  });
</script>

<style>
  .br-header {
    background: #071d41;
    border-bottom: 4px solid #1351b4;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }

  .br-header-top {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--gutter, 1.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 64px;
  }

  .br-header-logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .br-header-logo a:first-child {
    display: flex;
    align-items: center;
  }

  .br-header-divider {
    width: 1px;
    height: 28px;
    background: rgba(255,255,255,0.3);
    flex-shrink: 0;
  }

  .br-header-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    line-height: 1.3;
    max-width: 280px;
  }

  .br-header-title:hover {
    text-decoration: underline;
  }

  /* Nav */
  .br-header-nav {
    display: flex;
    align-items: center;
  }

  .br-header-nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
    align-items: center;
  }

  .br-header-nav-list a {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    border-radius: 4px;
    transition: background 150ms ease, color 150ms ease;
    white-space: nowrap;
  }

  .br-header-nav-list a:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
  }

  .br-header-nav-cta {
    background: #1351b4 !important;
    color: #fff !important;
    border-radius: 4px;
    font-weight: 600 !important;
  }

  .br-header-nav-cta:hover {
    background: #2670e8 !important;
  }

  /* Hamburger */
  .br-header-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 4px;
  }

  .br-header-menu-btn span {
    display: block;
    width: 100%;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .br-header-menu-btn:hover {
    background: rgba(255,255,255,0.1);
  }

  /* Mobile menu */
  .br-mobile-menu {
    background: #071d41;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 0.5rem 0;
  }

  .br-mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 1280px;
    margin: 0 auto;
  }

  .br-mobile-menu a {
    display: block;
    padding: 0.75rem var(--gutter, 1.5rem);
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 150ms ease;
  }

  .br-mobile-menu a:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  @media (max-width: 1024px) {
    .br-header-nav-list {
      display: none;
    }
    .br-header-menu-btn {
      display: flex;
    }
    .br-header-title {
      font-size: 0.8125rem;
      max-width: 200px;
    }
  }

  @media (max-width: 480px) {
    .br-header-title {
      display: none;
    }
  }
</style>
