---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import BrazilMap from "../components/BrazilMap.astro";
import Timeline from "../components/Timeline.astro";
import PartnerCard from "../components/PartnerCard.astro";
import Footer from "../components/Footer.astro";

const partners = [
  {
    name: "Instituto de Pesquisa em Dados Públicos",
    description: "Pesquisa aplicada e análise de dados governamentais abertos.",
  },
  {
    name: "Fórum Brasileiro de Participação Social",
    description: "Articulação nacional pela participação cidadã e democracia participativa.",
  },
  {
    name: "Laboratório de Inovação Cidadã",
    description: "Experimentação e desenvolvimento de metodologias participativas digitais.",
  },
  {
    name: "Rede de Transparência e Governo Aberto",
    description: "Promoção da transparência pública e abertura de dados governamentais.",
  },
  {
    name: "Centro de Estudos em Democracia Digital",
    description: "Pesquisa acadêmica sobre democracia, tecnologia e participação social.",
  },
  {
    name: "Observatório de Políticas Públicas",
    description: "Monitoramento e avaliação de políticas públicas baseadas em evidências.",
  },
];

const plataformas = [
  {
    nome: "Brasil Participativo",
    instituicao: "Secretaria-Geral da Presidência da República",
    esfera: "Federal",
    abrangencia: "Nacional",
    descricao: "Plataforma digital oficial do Governo Federal para consultas públicas, propostas e participação cidadã em políticas públicas.",
    link: "https://brasilparticipativo.presidencia.gov.br",
  },
  {
    nome: "Participa.br",
    instituicao: "Ministério da Gestão e Inovação",
    esfera: "Federal",
    abrangencia: "Nacional",
    descricao: "Ambiente virtual de participação social para consultas, conferências e diálogos entre governo e sociedade.",
    link: "#",
  },
  {
    nome: "Colab",
    instituicao: "Governos Municipais",
    esfera: "Municipal",
    abrangencia: "Vários municípios",
    descricao: "Plataforma de participação cidadã adotada por municípios brasileiros para reportar problemas urbanos e propor melhorias.",
    link: "#",
  },
  {
    nome: "e-Democracia",
    instituicao: "Câmara dos Deputados",
    esfera: "Federal",
    abrangencia: "Nacional",
    descricao: "Portal de participação legislativa que permite ao cidadão contribuir com propostas de lei e discussões temáticas.",
    link: "#",
  },
  {
    nome: "Lemonade",
    instituicao: "Organizações da Sociedade Civil",
    esfera: "Sociedade civil",
    abrangencia: "Nacional",
    descricao: "Ferramenta de consulta e engajamento comunitário utilizada por organizações da sociedade civil.",
    link: "#",
  },
  {
    nome: "Decidim",
    instituicao: "Prefeituras e Governos Estaduais",
    esfera: "Estadual",
    abrangencia: "Vários estados",
    descricao: "Plataforma de democracia participativa de código aberto adotada por governos estaduais e municipais.",
    link: "#",
  },
];

const pesquisas = [
  {
    titulo: "Participação Digital no Brasil: panorama e tendências",
    autores: "Silva, M. A.; Costa, R. P.",
    instituicao: "Universidade de Brasília",
    ano: 2023,
    tipo: "Artigo",
    resumo: "Análise abrangente dos padrões de participação digital no Brasil, com foco em plataformas governamentais e indicadores de engajamento.",
    link: "#",
  },
  {
    titulo: "Democracia participativa em ambientes digitais: desafios e oportunidades",
    autores: "Ferreira, L. C.",
    instituicao: "FGV",
    ano: 2022,
    tipo: "Relatório",
    resumo: "Relatório técnico sobre os principais desafios da democracia digital no contexto brasileiro, com recomendações para políticas públicas.",
    link: "#",
  },
  {
    titulo: "Perfil sociodemográfico dos participantes digitais",
    autores: "Oliveira, T. M.; Santos, A. R.",
    instituicao: "IPEA",
    ano: 2023,
    tipo: "Nota técnica",
    resumo: "Caracterização do perfil dos cidadãos que participam de consultas digitais, com análise de representatividade regional e sociodemográfica.",
    link: "#",
  },
];
---

<Layout>
  <Header />

  <main id="conteudo-principal">
    <Hero />

    <!-- Sobre o Observatório -->
    <Section id="sobre" ariaLabel="Sobre o Observatório">
      <h2>O OPD é do povo brasileiro</h2>
      <p class="text-body-lg section-intro">
        O Observatório Nacional da Participação Digital é uma iniciativa voltada à organização, análise e disponibilização de informações sobre práticas, plataformas e processos de participação social por meios digitais no Brasil. Seu objetivo é fortalecer a transparência pública, apoiar a tomada de decisão e ampliar o acesso da sociedade aos dados de participação.
      </p>
    </Section>

    <!-- Mapa Interativo -->
    <Section id="mapa" ariaLabel="Explore a participação em todo o Brasil" variant="dark">
      <span class="section-tag">Participação por território</span>
      <h2 class="on-dark">Explore a participação em todo o Brasil</h2>
      <p class="text-body-lg section-intro on-dark">
        Explore a participação digital nos municípios brasileiros e visualize dados sobre participantes, processos e plataformas por território.
      </p>

      <div class="mapa-layout">
        <div class="mapa-col">
          <BrazilMap />
        </div>

        <div class="mapa-sidebar">
          <div class="mapa-stats">
            <div class="mapa-stat">
              <span class="mapa-stat-value">27</span>
              <span class="mapa-stat-label">Estados participantes</span>
            </div>
            <div class="mapa-stat">
              <span class="mapa-stat-value">5.558</span>
              <span class="mapa-stat-label">Municípios participantes</span>
            </div>
            <div class="mapa-stat">
              <span class="mapa-stat-value">191</span>
              <span class="mapa-stat-label">Processos registrados</span>
            </div>
            <div class="mapa-stat">
              <span class="mapa-stat-value">947 mil</span>
              <span class="mapa-stat-label">Participantes</span>
            </div>
          </div>

          <a href="/explorar-dados" class="cta-mapa">
            Explorar Mapa Interativo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Section>

    <!-- Evolução da Participação Digital -->
    <Section id="evolucao" ariaLabel="Evolução da participação digital">
      <span class="section-tag-light">Série histórica</span>
      <h2>Evolução da participação digital</h2>
      <p class="text-body-lg section-intro">
        Acompanhe como os principais indicadores de participação digital evoluíram ao longo do tempo no Brasil.
      </p>

      <div class="evolucao-filters">
        <div class="filter-group">
          <label class="filter-label" for="filtro-indicador">Indicador</label>
          <select id="filtro-indicador" class="filter-select">
            <option>Inscritos na plataforma</option>
            <option>Visualizações da página</option>
            <option>Processos publicados</option>
          </select>
        </div>
        <div class="filter-group">
          <label class="filter-label" for="filtro-periodo">Período</label>
          <select id="filtro-periodo" class="filter-select">
            <option>Anual</option>
            <option>Trimestral</option>
            <option>Mensal</option>
          </select>
        </div>
      </div>

      <div class="chart-wrap">
        <canvas id="evolucao-chart" aria-label="Gráfico de linha da evolução da participação digital" role="img"></canvas>
        <div class="chart-tooltip" id="chart-tooltip" aria-hidden="true">
          <span class="tooltip-year" id="tooltip-year"></span>
          <span class="tooltip-value" id="tooltip-value"></span>
        </div>
        <p class="chart-note">Fonte: Brasil Participativo. Dados acumulados de participantes registrados.</p>
      </div>

      <script>
        const datasets = {
          "Inscritos na plataforma": [
            { ano: 2017, valor: 4200 },
            { ano: 2018, valor: 12800 },
            { ano: 2019, valor: 27500 },
            { ano: 2020, valor: 51000 },
            { ano: 2021, valor: 98000 },
            { ano: 2022, valor: 210000 },
            { ano: 2023, valor: 520000 },
            { ano: 2024, valor: 947000 },
          ],
          "Visualizações da página": [
            { ano: 2017, valor: 18000 },
            { ano: 2018, valor: 45000 },
            { ano: 2019, valor: 89000 },
            { ano: 2020, valor: 160000 },
            { ano: 2021, valor: 310000 },
            { ano: 2022, valor: 680000 },
            { ano: 2023, valor: 1400000 },
            { ano: 2024, valor: 2800000 },
          ],
          "Processos publicados": [
            { ano: 2017, valor: 3 },
            { ano: 2018, valor: 8 },
            { ano: 2019, valor: 18 },
            { ano: 2020, valor: 34 },
            { ano: 2021, valor: 62 },
            { ano: 2022, valor: 110 },
            { ano: 2023, valor: 158 },
            { ano: 2024, valor: 191 },
          ],
        };

        function formatVal(v, label) {
          if (label === "Processos publicados") return v.toLocaleString("pt-BR");
          if (v >= 1000000) return (v / 1000000).toFixed(1).replace(".", ",") + " mi";
          if (v >= 1000) return (v / 1000).toFixed(0) + " mil";
          return v.toLocaleString("pt-BR");
        }

        function drawChart(label) {
          const canvas = document.getElementById("evolucao-chart");
          if (!canvas) return;
          const dpr = window.devicePixelRatio || 1;
          const W = canvas.offsetWidth;
          const H = canvas.offsetHeight;
          canvas.width = W * dpr;
          canvas.height = H * dpr;
          const ctx = canvas.getContext("2d");
          ctx.scale(dpr, dpr);

          const data = datasets[label];
          const PAD = { top: 24, right: 24, bottom: 40, left: 60 };
          const cW = W - PAD.left - PAD.right;
          const cH = H - PAD.top - PAD.bottom;

          const vals = data.map(d => d.valor);
          const maxV = Math.max(...vals);
          const minV = 0;

          const xOf = i => PAD.left + (i / (data.length - 1)) * cW;
          const yOf = v => PAD.top + cH - ((v - minV) / (maxV - minV)) * cH;

          // Grid lines
          const ticks = 5;
          ctx.strokeStyle = "#e5e7eb";
          ctx.lineWidth = 1;
          for (let i = 0; i <= ticks; i++) {
            const y = PAD.top + (cH / ticks) * i;
            ctx.beginPath(); ctx.moveTo(PAD.left, y); ctx.lineTo(PAD.left + cW, y); ctx.stroke();
            const tickVal = maxV - (maxV / ticks) * i;
            ctx.fillStyle = "#6b7280";
            ctx.font = "11px Inter, sans-serif";
            ctx.textAlign = "right";
            ctx.fillText(formatVal(Math.round(tickVal), label), PAD.left - 8, y + 4);
          }

          // Area fill
          const grad = ctx.createLinearGradient(0, PAD.top, 0, PAD.top + cH);
          grad.addColorStop(0, "rgba(24,73,155,0.18)");
          grad.addColorStop(1, "rgba(24,73,155,0.01)");
          ctx.beginPath();
          ctx.moveTo(xOf(0), yOf(vals[0]));
          for (let i = 1; i < data.length; i++) {
            const x0 = xOf(i - 1), y0 = yOf(vals[i - 1]);
            const x1 = xOf(i),     y1 = yOf(vals[i]);
            const cpx = (x0 + x1) / 2;
            ctx.bezierCurveTo(cpx, y0, cpx, y1, x1, y1);
          }
          ctx.lineTo(xOf(data.length - 1), PAD.top + cH);
          ctx.lineTo(xOf(0), PAD.top + cH);
          ctx.closePath();
          ctx.fillStyle = grad;
          ctx.fill();

          // Line
          ctx.beginPath();
          ctx.moveTo(xOf(0), yOf(vals[0]));
          for (let i = 1; i < data.length; i++) {
            const x0 = xOf(i - 1), y0 = yOf(vals[i - 1]);
            const x1 = xOf(i),     y1 = yOf(vals[i]);
            const cpx = (x0 + x1) / 2;
            ctx.bezierCurveTo(cpx, y0, cpx, y1, x1, y1);
          }
          ctx.strokeStyle = "#18499b";
          ctx.lineWidth = 2.5;
          ctx.lineJoin = "round";
          ctx.stroke();

          // Dots + X labels
          data.forEach((d, i) => {
            const x = xOf(i), y = yOf(d.valor);
            ctx.beginPath();
            ctx.arc(x, y, 4.5, 0, Math.PI * 2);
            ctx.fillStyle = "#fff";
            ctx.strokeStyle = "#18499b";
            ctx.lineWidth = 2;
            ctx.fill(); ctx.stroke();

            ctx.fillStyle = "#6b7280";
            ctx.font = "11px Inter, sans-serif";
            ctx.textAlign = "center";
            ctx.fillText(String(d.ano), x, PAD.top + cH + 22);
          });
        }

        // Tooltip
        function setupTooltip(label) {
          const canvas = document.getElementById("evolucao-chart");
          const tooltip = document.getElementById("chart-tooltip");
          const tipYear = document.getElementById("tooltip-year");
          const tipVal = document.getElementById("tooltip-value");
          if (!canvas || !tooltip) return;

          const data = datasets[label];
          const PAD = { top: 24, right: 24, bottom: 40, left: 60 };

          canvas.onmousemove = (e) => {
            const rect = canvas.getBoundingClientRect();
            const mx = e.clientX - rect.left;
            const cW = rect.width - PAD.left - PAD.right;
            const step = cW / (data.length - 1);
            const idx = Math.round((mx - PAD.left) / step);
            if (idx < 0 || idx >= data.length) { tooltip.hidden = true; return; }
            const d = data[idx];
            tipYear.textContent = String(d.ano);
            tipVal.textContent = formatVal(d.valor, label);
            tooltip.hidden = false;
            const x = PAD.left + (idx / (data.length - 1)) * cW;
            tooltip.style.left = (x / rect.width * 100) + "%";
          };
          canvas.onmouseleave = () => { tooltip.hidden = true; };
        }

        let currentLabel = "Inscritos na plataforma";

        function init() {
          drawChart(currentLabel);
          setupTooltip(currentLabel);
        }

        window.addEventListener("resize", () => drawChart(currentLabel));
        document.getElementById("filtro-indicador")?.addEventListener("change", (e) => {
          currentLabel = (e.target as HTMLSelectElement).value;
          drawChart(currentLabel);
          setupTooltip(currentLabel);
        });

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      </script>
    </Section>

    <!-- Linha do Tempo -->
    <Section id="linha-do-tempo" ariaLabel="Linha do Tempo da Participação Social">
      <h2>Linha do Tempo da Participação Social</h2>
      <p class="text-body-lg section-intro">
        Marcos, plataformas, processos e atualizações que ajudam a compreender a evolução da participação digital.
      </p>

      <Timeline />
    </Section>

    <!-- Banner Dados Abertos Brasil Participativo -->
    <Section id="dados-abertos" ariaLabel="Acesse os dados abertos do Brasil Participativo" variant="dark">
      <div class="banner-dados">
        <div class="banner-dados-content">
          <span class="section-tag">Dados abertos</span>
          <h2 class="on-dark">Acesse os dados abertos do Brasil Participativo</h2>
          <p class="text-body-lg on-dark">
            Consulte bases públicas, indicadores e informações estruturadas sobre processos de participação digital realizados no Brasil Participativo.
          </p>
          <a
            href="https://dados.gov.br/dados/busca?termo=Brasil%20Participativo"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-primary"
          >
            Acessar dados abertos
          </a>
        </div>
        <div class="banner-dados-deco" aria-hidden="true">
          <div class="deco-icon">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
              <rect x="8" y="8" width="48" height="48" rx="8" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
              <path d="M20 44V28M28 44V20M36 44V32M44 44V24" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
      </div>
    </Section>

    <!-- Plataformas de Participação Digital -->
    <Section id="plataformas" ariaLabel="Plataformas de participação digital">
      <span class="section-tag-light">Ecossistema</span>
      <h2>Plataformas de participação digital</h2>
      <p class="text-body-lg section-intro">
        Conheça as plataformas digitais utilizadas para promover participação social, consultas públicas, propostas, votações e outras formas de colaboração cidadã.
      </p>

      <div class="plataformas-filters">
        <button class="filter-chip active">Todas</button>
        <button class="filter-chip">Federal</button>
        <button class="filter-chip">Estadual</button>
        <button class="filter-chip">Municipal</button>
        <button class="filter-chip">Sociedade civil</button>
      </div>

      <div class="plataformas-grid">
        {plataformas.map(p => (
          <a href={p.link} target="_blank" rel="noopener noreferrer" class="plataforma-card">
            <div class="plataforma-header">
              <span class="plataforma-nome">{p.nome}</span>
              <span class="plataforma-esfera">{p.esfera}</span>
            </div>
            <span class="plataforma-instituicao">{p.instituicao}</span>
            <p class="plataforma-desc">{p.descricao}</p>
            <span class="plataforma-abrangencia">{p.abrangencia}</span>
          </a>
        ))}
      </div>
    </Section>

    <!-- Repositório de Pesquisas -->
    <Section id="pesquisas" ariaLabel="Repositório de pesquisas sobre participação digital">
      <span class="section-tag-light">Conhecimento</span>
      <h2>Repositório de pesquisas sobre participação digital</h2>
      <p class="text-body-lg section-intro">
        Explore estudos, artigos, relatórios e publicações sobre participação social digital, democracia participativa, governo aberto e tecnologias cívicas.
      </p>

      <div class="pesquisas-grid">
        {pesquisas.map(p => (
          <article class="pesquisa-card">
            <div class="pesquisa-header">
              <span class="pesquisa-tipo">{p.tipo}</span>
              <span class="pesquisa-ano">{p.ano}</span>
            </div>
            <h3 class="pesquisa-titulo">{p.titulo}</h3>
            <p class="pesquisa-autores">{p.autores} — {p.instituicao}</p>
            <p class="pesquisa-resumo">{p.resumo}</p>
            <a href={p.link} class="pesquisa-link">Ver publicação →</a>
          </article>
        ))}
      </div>

      <div class="pesquisas-footer">
        <a href="#" class="cta-outline">Ver todas as pesquisas</a>
      </div>
    </Section>

    <!-- Formulário para submeter pesquisas -->
    <Section id="submeter-pesquisa" ariaLabel="Submeta uma pesquisa">
      <span class="section-tag-light">Colabore</span>
      <h2>Submeta uma pesquisa</h2>
      <p class="text-body-lg section-intro">
        Contribua com o fortalecimento do conhecimento sobre participação digital no Brasil enviando pesquisas, relatórios, artigos e publicações para avaliação.
      </p>
      <button class="btn-submit" id="btn-abrir-modal" type="button">
        Submeter pesquisa
      </button>
    </Section>

    <!-- Modal de submissão de pesquisa -->
    <dialog class="modal-pesquisa" id="modal-pesquisa" aria-labelledby="modal-pesquisa-titulo" aria-modal="true">
      <div class="modal-inner">
        <div class="modal-header">
          <h2 class="modal-titulo" id="modal-pesquisa-titulo">Submeta uma pesquisa</h2>
          <button class="modal-fechar" id="modal-fechar" type="button" aria-label="Fechar">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <div class="modal-body">
          <form class="form-pesquisa" id="form-pesquisa" novalidate>
            <fieldset class="form-fieldset">
              <legend class="form-legend">Dados do responsável pela submissão</legend>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="resp-nome">Nome completo <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="resp-nome" name="nome" required autocomplete="name" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="resp-email">E-mail <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="email" id="resp-email" name="email" required autocomplete="email" />
                </div>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="resp-instituicao">Instituição ou organização <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="resp-instituicao" name="instituicao" required />
                </div>
                <div class="form-field">
                  <label class="form-label" for="resp-cargo">Cargo ou vínculo institucional <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="resp-cargo" name="cargo" required />
                </div>
              </div>
              <div class="form-field form-field--half">
                <label class="form-label" for="resp-telefone">Telefone <span class="form-optional">(opcional)</span></label>
                <input class="form-input" type="tel" id="resp-telefone" name="telefone" autocomplete="tel" />
              </div>
            </fieldset>

            <fieldset class="form-fieldset">
              <legend class="form-legend">Dados da pesquisa</legend>
              <div class="form-field">
                <label class="form-label" for="pesq-titulo">Título da pesquisa <span aria-hidden="true">*</span></label>
                <input class="form-input" type="text" id="pesq-titulo" name="pesq_titulo" required />
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="pesq-autores">Autor(es) <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="pesq-autores" name="autores" required placeholder="Sobrenome, Nome; Sobrenome, Nome" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="pesq-ano">Ano de publicação <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="number" id="pesq-ano" name="ano" min="1990" max="2030" required />
                </div>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="pesq-tipo">Tipo de publicação <span aria-hidden="true">*</span></label>
                  <select class="form-select" id="pesq-tipo" name="tipo" required>
                    <option value="">Selecione…</option>
                    <option>Artigo</option>
                    <option>Relatório</option>
                    <option>Dissertação</option>
                    <option>Tese</option>
                    <option>Livro</option>
                    <option>Capítulo</option>
                    <option>Nota técnica</option>
                    <option>Outro</option>
                  </select>
                </div>
                <div class="form-field">
                  <label class="form-label" for="pesq-idioma">Idioma da publicação <span aria-hidden="true">*</span></label>
                  <select class="form-select" id="pesq-idioma" name="idioma" required>
                    <option value="">Selecione…</option>
                    <option>Português</option>
                    <option>Inglês</option>
                    <option>Espanhol</option>
                    <option>Outro</option>
                  </select>
                </div>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="pesq-tema">Tema principal <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="pesq-tema" name="tema" required />
                </div>
                <div class="form-field">
                  <label class="form-label" for="pesq-palavras">Palavras-chave <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="pesq-palavras" name="palavras_chave" required placeholder="Separadas por vírgula" />
                </div>
              </div>
              <div class="form-field">
                <label class="form-label" for="pesq-resumo">Resumo <span aria-hidden="true">*</span></label>
                <textarea class="form-textarea" id="pesq-resumo" name="resumo" required rows="4" placeholder="Breve resumo da pesquisa…"></textarea>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="pesq-link">Link de acesso <span class="form-optional">(opcional)</span></label>
                  <input class="form-input" type="url" id="pesq-link" name="link" placeholder="https://" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="pesq-doi">DOI <span class="form-optional">(opcional)</span></label>
                  <input class="form-input" type="text" id="pesq-doi" name="doi" placeholder="10.xxxx/xxxxx" />
                </div>
              </div>
              <div class="form-field">
                <label class="form-label" for="pesq-arquivo">Arquivo para upload <span class="form-optional">(opcional)</span></label>
                <input class="form-input form-file" type="file" id="pesq-arquivo" name="arquivo" accept=".pdf,.doc,.docx" />
                <span class="form-hint">PDF, DOC ou DOCX. Máximo 20 MB.</span>
              </div>
            </fieldset>

            <fieldset class="form-fieldset">
              <legend class="form-legend">Autorização e revisão</legend>
              <div class="form-checks">
                <label class="form-check">
                  <input type="checkbox" name="autoriza_analise" required />
                  <span>Autorizo a análise desta submissão pela equipe do Observatório.</span>
                </label>
                <label class="form-check">
                  <input type="checkbox" name="confirma_veracidade" required />
                  <span>Confirmo que as informações enviadas são verdadeiras e de minha responsabilidade.</span>
                </label>
                <label class="form-check">
                  <input type="checkbox" name="ciente_curadoria" required />
                  <span>Estou ciente de que a submissão passará por curadoria antes de ser publicada.</span>
                </label>
              </div>
              <div class="form-field" style="margin-top: var(--space-lg)">
                <label class="form-label" for="pesq-obs">Observações adicionais <span class="form-optional">(opcional)</span></label>
                <textarea class="form-textarea" id="pesq-obs" name="observacoes" rows="3" placeholder="Informações complementares que deseje compartilhar…"></textarea>
              </div>
            </fieldset>

            <div class="form-actions">
              <button type="submit" class="btn-submit">Enviar pesquisa</button>
              <button type="button" class="btn-cancelar" id="btn-cancelar">Cancelar</button>
            </div>

            <div class="form-success" id="form-pesquisa-success" hidden aria-live="polite">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div>
                <strong>Submissão recebida!</strong>
                <p>Obrigado pela contribuição. Nossa equipe avaliará a pesquisa e entrará em contato em até 15 dias úteis.</p>
              </div>
            </div>
          </form>
        </div>
      </div>
    </dialog>

    <script>
      const modal = document.getElementById("modal-pesquisa") as HTMLDialogElement;
      document.getElementById("btn-abrir-modal")?.addEventListener("click", () => modal?.showModal());
      document.getElementById("modal-fechar")?.addEventListener("click", () => modal?.close());
      document.getElementById("btn-cancelar")?.addEventListener("click", () => modal?.close());
      modal?.addEventListener("click", (e) => { if (e.target === modal) modal.close(); });

      document.getElementById("form-pesquisa")?.addEventListener("submit", (e) => {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        if (!form.checkValidity()) { form.reportValidity(); return; }
        form.querySelectorAll("input,select,textarea,button").forEach((el: any) => el.disabled = true);
        const success = document.getElementById("form-pesquisa-success") as HTMLElement;
        success.hidden = false;
        success.scrollIntoView({ behavior: "smooth", block: "nearest" });
      });
    </script>

    <!-- Apoiadores e parceiros -->
    <Section id="parceiros" ariaLabel="Apoiadores e parceiros" variant="parceiros">
      <h2 class="on-dark">Apoiadores e parceiros</h2>
      <p class="text-body-lg section-intro on-dark">
        Quer contribuir com o Observatório de Participação Digital? Pesquisadores, gestores municipais, instituições e provedores de serviços podem manifestar interesse em colaborar com o fortalecimento da participação digital no Brasil.
      </p>

      <form class="form-interesse" id="form-interesse" novalidate>
        <div class="form-row">
          <div class="form-field">
            <label class="form-label form-label--dark" for="int-nome">Nome completo <span aria-hidden="true">*</span></label>
            <input class="form-input form-input--dark" type="text" id="int-nome" name="nome" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label class="form-label form-label--dark" for="int-telefone">Telefone <span aria-hidden="true">*</span></label>
            <input class="form-input form-input--dark" type="tel" id="int-telefone" name="telefone" required autocomplete="tel" />
          </div>
        </div>
        <div class="form-field form-field--half">
          <label class="form-label form-label--dark" for="int-perfil">Perfil <span aria-hidden="true">*</span></label>
          <select class="form-select form-select--dark" id="int-perfil" name="perfil" required>
            <option value="">Selecione seu perfil…</option>
            <option value="pesquisador">Pesquisador — uso dos dados para pesquisa</option>
            <option value="provedor">Provedor de serviços — integração ou suporte técnico</option>
            <option value="gestor">Gestor municipal — compartilhar dados ou conhecer a participação no município</option>
          </select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn-submit btn-submit--light">Enviar interesse</button>
        </div>
        <div class="form-success form-success--dark" id="form-interesse-success" hidden aria-live="polite">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div>
            <strong>Interesse registrado!</strong>
            <p>Nossa equipe entrará em contato em breve para dar continuidade à colaboração.</p>
          </div>
        </div>
      </form>

      <script>
        document.getElementById("form-interesse")?.addEventListener("submit", (e) => {
          e.preventDefault();
          const form = e.target as HTMLFormElement;
          if (!form.checkValidity()) { form.reportValidity(); return; }
          form.querySelectorAll("input,select,button").forEach((el: any) => el.disabled = true);
          (document.getElementById("form-interesse-success") as HTMLElement).hidden = false;
        });
      </script>
    </Section>
  </main>

  <Footer />
</Layout>

<style>
